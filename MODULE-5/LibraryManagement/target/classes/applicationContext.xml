<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xmlns:aop="http://www.springframework.org/schema/aop"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd
           http://www.springframework.org/schema/context
           http://www.springframework.org/schema/context/spring-context.xsd
           http://www.springframework.org/schema/aop
           http://www.springframework.org/schema/aop/spring-aop.xsd">

    <!-- ============================================================ -->
    <!-- Exercise 3 & 8 — Enable AspectJ auto-proxying for AOP        -->
    <!-- ============================================================ -->
    <aop:aspectj-autoproxy/>

    <!-- ============================================================ -->
    <!-- Exercise 1, 2, 5 — Explicit bean definitions                 -->
    <!-- (component scan picks these up via annotations too,          -->
    <!--  but shown here to demonstrate XML config)                   -->
    <!-- ============================================================ -->

    <!-- BookRepository bean -->
    <bean id="bookRepository" class="com.library.repository.BookRepository"/>

    <!-- Exercise 7a — Constructor Injection                          -->
    <!-- BookService with constructor injection for bookRepository    -->
    <bean id="bookServiceConstructor" class="com.library.service.BookService">
        <constructor-arg ref="bookRepository"/>
    </bean>

    <!-- Exercise 7b — Setter Injection                               -->
    <!-- BookService with setter injection for bookRepository         -->
    <bean id="bookServiceSetter" class="com.library.service.BookService">
        <property name="bookRepository" ref="bookRepository"/>
    </bean>

    <!-- Exercise 3 & 8 — Register the LoggingAspect bean            -->
    <bean id="loggingAspect" class="com.library.aspect.LoggingAspect"/>

</beans>